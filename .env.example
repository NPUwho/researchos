# ResearchOS root environment example.
# Copy to .env for local (non-Docker) development. The Docker Compose stack
# sets service-to-service values directly and does not require this file.

# --- General -----------------------------------------------------------------
ENVIRONMENT=local
DEBUG=false

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=true

# --- API server --------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- PostgreSQL (pgvector) ---------------------------------------------------
POSTGRES_DSN=postgresql+asyncpg://researchos:researchos@localhost:5432/researchos

# --- Redis / Celery ----------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
# Optional explicit overrides; default to REDIS_URL when unset.
# CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=

# --- Object storage (MinIO / S3) ---------------------------------------------
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=researchos
S3_SECRET_KEY=researchos
S3_BUCKET=researchos

# --- Workspace (IDE) ---------------------------------------------------------
# Base directory holding per-project workspaces (<workspace_root>/<project_id>).
WORKSPACE_ROOT=/data/workspaces

# --- LLM provider ------------------------------------------------------------
# "mock" (default; no external calls) or "anthropic" (requires key + model).
LLM_PROVIDER=mock
LLM_MODEL=mock-model
# ANTHROPIC_API_KEY=

# --- Frontend ----------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
